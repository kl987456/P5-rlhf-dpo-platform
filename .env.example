# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, no extra setup):
DATABASE_URL=sqlite:///./rlhf.db

# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+psycopg2://rlhf:rlhf_secret@localhost:5432/rlhf_platform

# ── Redis / Celery (training jobs dispatched as Celery tasks) ─────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Model training ─────────────────────────────────────────────────────────────
# Base model for SFT → reward model → DPO pipeline
BASE_MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct

# Local directory for saving checkpoints
OUTPUT_DIR=./checkpoints

# Hugging Face token (required for gated models like Llama)
HF_TOKEN=hf_...

# Hugging Face repo to push trained models to (leave blank to skip)
HF_PUSH_REPO=

# ── Inference server ───────────────────────────────────────────────────────────
SERVING_HOST=0.0.0.0
SERVING_PORT=8080
MAX_NEW_TOKENS=512

# ── Security ───────────────────────────────────────────────────────────────────
API_KEY=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8004
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60
